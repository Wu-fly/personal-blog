package com.blog.controller;

import com.blog.dto.*;
import com.blog.entity.Transaction;
import com.blog.entity.Wallet;
import com.blog.security.CustomUserDetails;
import com.blog.service.WalletService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.data.domain.Page;
import org.springframework.data.domain.PageRequest;
import org.springframework.data.domain.Pageable;
import org.springframework.data.domain.Sort;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.security.core.annotation.AuthenticationPrincipal;
import org.springframework.validation.annotation.Validated;
import org.springframework.web.bind.annotation.*;

import javax.validation.Valid;
import javax.validation.constraints.Min;

/**
 * йТ±еМЕжОІеИґеЩ?
 * е§ДзРЖеЕЕеАЉгАБжПРзО∞гАБдљЩйҐЭжЯ•иѓҐгАБдЇ§жШУиЃ∞ељХз≠ЙжО•еП£
 * йЬАж±? 18.1-18.8, 30.1-30.5
 */
@Slf4j
@RestController
@RequestMapping("/wallet")
@RequiredArgsConstructor
@Validated
public class WalletController {

    private final WalletService walletService;

    /**
     * еЕЕеА?
     * POST /api/wallet/recharge
     * йЬАж±? 30.1-30.5
     */
    @PostMapping("/recharge")
    @PreAuthorize("isAuthenticated()")
    public ResponseEntity<ApiResponse<WalletResponse>> recharge(
            @AuthenticationPrincipal CustomUserDetails userDetails,
            @Valid @RequestBody RechargeRequest request) {
        log.info("User {} recharging amount: {}", userDetails.getId(), request.getAmount());
        
        Wallet wallet = walletService.recharge(userDetails.getId(), request.getAmount());
        WalletResponse response = convertToWalletResponse(wallet);
        
        return ResponseEntity.ok(ApiResponse.success("еЕЕеАЉжИРеК?, response));
    }

    /**
     * жПРзО∞
     * POST /api/wallet/withdraw
     * йЬАж±? 18.4-18.8
     */
    @PostMapping("/withdraw")
    @PreAuthorize("isAuthenticated()")
    public ResponseEntity<ApiResponse<WalletResponse>> withdraw(
            @AuthenticationPrincipal CustomUserDetails userDetails,
            @Valid @RequestBody WithdrawRequest request) {
        log.info("User {} withdrawing amount: {}", userDetails.getId(), request.getAmount());
        
        Wallet wallet = walletService.withdraw(userDetails.getId(), request.getAmount());
        WalletResponse response = convertToWalletResponse(wallet);
        
        return ResponseEntity.ok(ApiResponse.success("жПРзО∞зФ≥иѓЈеЈ≤жПРдЇ?, response));
    }

    /**
     * иОЈеПЦйТ±еМЕдљЩйҐЭ
     * GET /api/wallet/balance
     * йЬАж±? 18.1
     */
    @GetMapping("/balance")
    @PreAuthorize("isAuthenticated()")
    public ResponseEntity<ApiResponse<WalletResponse>> getBalance(
            @AuthenticationPrincipal CustomUserDetails userDetails) {
        log.info("Getting wallet balance for user: {}", userDetails.getId());
        
        Wallet wallet = walletService.getBalance(userDetails.getId());
        WalletResponse response = convertToWalletResponse(wallet);
        
        return ResponseEntity.ok(ApiResponse.success(response));
    }

    /**
     * иОЈеПЦдЇ§жШУиЃ∞ељХ
     * GET /api/wallet/transactions
     * йЬАж±? 18.2, 30.5
     */
    @GetMapping("/transactions")
    @PreAuthorize("isAuthenticated()")
    public ResponseEntity<ApiResponse<Page<TransactionResponse>>> getTransactions(
            @AuthenticationPrincipal CustomUserDetails userDetails,
            @RequestParam(defaultValue = "0") @Min(0) int page,
            @RequestParam(defaultValue = "20") @Min(1) int size) {
        log.info("Getting transactions for user: {}, page: {}, size: {}", 
                userDetails.getId(), page, size);
        
        Pageable pageable = PageRequest.of(page, size, Sort.by(Sort.Direction.DESC, "createdAt"));
        Page<Transaction> transactions = walletService.getTransactions(userDetails.getId(), pageable);
        Page<TransactionResponse> response = transactions.map(this::convertToTransactionResponse);
        
        return ResponseEntity.ok(ApiResponse.success(response));
    }

    /**
     * иОЈеПЦжФґзЫКжШОзїЖ
     * GET /api/wallet/revenue
     * йЬАж±? 18.3
     */
    @GetMapping("/revenue")
    @PreAuthorize("hasAnyRole('BLOGGER', 'ADMIN')")
    public ResponseEntity<ApiResponse<Page<TransactionResponse>>> getRevenue(
            @AuthenticationPrincipal CustomUserDetails userDetails,
            @RequestParam(defaultValue = "0") @Min(0) int page,
            @RequestParam(defaultValue = "20") @Min(1) int size) {
        log.info("Getting revenue for user: {}, page: {}, size: {}", 
                userDetails.getId(), page, size);
        
        Pageable pageable = PageRequest.of(page, size, Sort.by(Sort.Direction.DESC, "createdAt"));
        Page<Transaction> revenue = walletService.getRevenue(userDetails.getId(), pageable);
        Page<TransactionResponse> response = revenue.map(this::convertToTransactionResponse);
        
        return ResponseEntity.ok(ApiResponse.success(response));
    }

    /**
     * иљђжНҐWalletеЃЮдљУдЄЇWalletResponse DTO
     */
    private WalletResponse convertToWalletResponse(Wallet wallet) {
        return WalletResponse.builder()
                .id(wallet.getId())
                .userId(wallet.getUserId())
                .balance(wallet.getBalance())
                .totalIncome(wallet.getTotalIncome())
                .totalWithdraw(wallet.getTotalWithdraw())
                .createdAt(wallet.getCreatedAt())
                .updatedAt(wallet.getUpdatedAt())
                .build();
    }

    /**
     * иљђжНҐTransactionеЃЮдљУдЄЇTransactionResponse DTO
     */
    private TransactionResponse convertToTransactionResponse(Transaction transaction) {
        return TransactionResponse.builder()
                .id(transaction.getId())
                .type(transaction.getType())
                .amount(transaction.getAmount())
                .balanceAfter(transaction.getBalanceAfter())
                .relatedUserId(transaction.getRelatedUserId())
                .relatedUserNickname(null) // TODO: йЬАи¶БдїОUserи°®жЯ•иѓ?
                .relatedArticleId(transaction.getRelatedArticleId())
                .relatedArticleTitle(null) // TODO: йЬАи¶БдїОArticleи°®жЯ•иѓ?
                .status(transaction.getStatus())
                .description(transaction.getDescription())
                .createdAt(transaction.getCreatedAt())
                .build();
    }
}

